datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  logoUrl     String?
  coverUrl    String?
  description String?
  isActive    Boolean      @default(true)
  features    String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  services    Service[]
  employees   Employee[]
  bookings    Booking[]
  tenantPlans TenantPlan[]

  // Theme Settings
  themeBgColor     String?
  themeButtonColor String?

  // WhatsApp Integration Settings
  whatsappEnabled          Boolean   @default(false)
  whatsappProvider         String    @default("simulador") // "simulador", "evolution", "meta"
  whatsappApiUrl           String?
  whatsappToken            String?
  whatsappNumber           String?   // Nome da Instância (Evolution) ou Phone Number ID (Meta)
  whatsappWabaId           String?   // Meta WABA ID

  // WhatsApp Automations
  whatsappConfirmEnabled   Boolean   @default(false)
  whatsappConfirmTemplate  String?   @default("Olá {nome}, seu agendamento para {servico} com {profissional} no dia {data} às {hora} foi confirmado!")

  whatsappReminderEnabled  Boolean   @default(false)
  whatsappReminderHours    Int       @default(2)
  whatsappReminderTemplate String?   @default("Olá {nome}, passando para lembrar do seu horário de {servico} hoje às {hora} com {profissional}!")

  whatsappInactiveEnabled  Boolean   @default(false)
  whatsappInactiveDays     Int       @default(30)
  whatsappInactiveTemplate String?   @default("Olá {nome}, faz {dias} dias que você não nos visita! Que tal agendar um novo horário?")

  // WhatsApp cancellation notification to professional
  whatsappCancelNotifyEnabled  Boolean @default(true)
  whatsappCancelNotifyTemplate String? @default("Olá {profissional}, o cliente {nome} desmarcou o agendamento de {servico} do dia {data} às {hora}.")

  customerPlans         CustomerPlan[]
  customerSubscriptions CustomerSubscription[]
  expenses              Expense[]
}

model Plan {
  id           String       @id @default(uuid())
  name         String       // e.g. "Básico", "Pro", "Enterprise"
  price        Float        // monthly price in BRL
  features     String[]     @default([]) // feature slugs included in this plan
  maxEmployees Int          @default(1)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenantPlans  TenantPlan[]
}

model TenantPlan {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  startDate DateTime  @default(now())
  endDate   DateTime?
  status    String    @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  createdAt DateTime  @default(now())
}

model Service {
  id          String     @id @default(uuid())
  name        String
  description String?
  price       Float
  duration    Int        // duration in minutes
  category    String     // e.g. "Cabelo", "Barba", "Combos"
  imageUrl    String?    // URL for the service photo
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookings    Booking[]
  employees   Employee[]
}

model Employee {
  id                 String     @id @default(uuid())
  name               String
  role               String     // e.g. "Barbeiro", "Maquiador"
  email              String?    @unique
  passwordHash       String?
  isAdmin            Boolean    @default(false)
  avatarUrl          String?
  googleCalendarSync Boolean    @default(false)
  calendarToken      String?    // Refresh token for OAuth Google Calendar Sync
  phone              String?
  commissionRate     Float      @default(50.0) // Percentage of commission (e.g. 50.0 = 50%)
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  bookings           Booking[]
  schedules          EmployeeSchedule[]
  services           Service[]
}

model EmployeeSchedule {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      // 0 = Domingo, 1 = Segunda, 2 = Terça...
  startTime  String   // e.g. "09:00"
  endTime    String   // e.g. "12:00"
}

model Client {
  id        String    @id @default(uuid())
  name      String
  phone     String    @unique // unique phone number verified by OTP
  email     String?   @unique // optional, used when logging in with Google/Apple
  googleId  String?   @unique // unique identifier for Google OAuth login
  appleId   String?   @unique // unique identifier for Apple OAuth login
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]

  whatsappInactiveSentAt DateTime?
  customerSubscriptions  CustomerSubscription[]
}

model Booking {
  id                     String                @id @default(uuid())
  date                   DateTime // Selected date & time
  status                 String                @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  notes                  String?
  tenantId               String
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId              String
  service                Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  employeeId             String
  employee               Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clientId               String
  client                 Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerSubscriptionId String?
  customerSubscription   CustomerSubscription? @relation(fields: [customerSubscriptionId], references: [id], onDelete: SetNull)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  whatsappReminderSent Boolean @default(false)
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RateLimitState {
  key          String   @id
  count        Int      @default(0)
  windowStart  DateTime
  blockedUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WhatsappLog {
  id         String   @id @default(uuid())
  tenantId   String
  recipient  String
  message    String
  type       String   // CONFIRMATION, REMINDER, INACTIVE, TEST
  status     String   // SENT, FAILED, SIMULATED
  createdAt  DateTime @default(now())
}

model CustomerPlan {
  id           String                 @id @default(uuid())
  name         String                 // ex: "Clube da Barba Mensal"
  price        Float                  // Preço cobrado do cliente
  slots        Int                    // Qtd de agendamentos inclusos
  periodDays   Int                    @default(30)
  tenantId     String
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  subscriptions CustomerSubscription[]
}

model CustomerSubscription {
  id             String        @id @default(uuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId         String
  plan           CustomerPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startDate      DateTime      @default(now())
  endDate        DateTime
  status         String        @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  remainingSlots Int           // Slots restantes no ciclo atual
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  bookings       Booking[]
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime
  category    String   // ex: "Aluguel", "Energia", "Produtos", "Marketing", "Outros"
  tenantId    String
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
