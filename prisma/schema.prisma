datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  logoUrl     String?
  coverUrl    String?
  description String?
  isActive    Boolean      @default(true)
  features    String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  services    Service[]
  employees   Employee[]
  bookings    Booking[]
  tenantPlans TenantPlan[]
}

model Plan {
  id           String       @id @default(uuid())
  name         String       // e.g. "Básico", "Pro", "Enterprise"
  price        Float        // monthly price in BRL
  features     String[]     @default([]) // feature slugs included in this plan
  maxEmployees Int          @default(1)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenantPlans  TenantPlan[]
}

model TenantPlan {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  startDate DateTime  @default(now())
  endDate   DateTime?
  status    String    @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  createdAt DateTime  @default(now())
}

model Service {
  id          String     @id @default(uuid())
  name        String
  description String?
  price       Float
  duration    Int        // duration in minutes
  category    String     // e.g. "Cabelo", "Barba", "Combos"
  imageUrl    String?    // URL for the service photo
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookings    Booking[]
  employees   Employee[]
}

model Employee {
  id                 String     @id @default(uuid())
  name               String
  role               String     // e.g. "Barbeiro", "Maquiador"
  email              String?    @unique
  passwordHash       String?
  isAdmin            Boolean    @default(false)
  avatarUrl          String?
  googleCalendarSync Boolean    @default(false)
  calendarToken      String?    // Refresh token for OAuth Google Calendar Sync
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  bookings           Booking[]
  schedules          EmployeeSchedule[]
  services           Service[]
}

model EmployeeSchedule {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      // 0 = Domingo, 1 = Segunda, 2 = Terça...
  startTime  String   // e.g. "09:00"
  endTime    String   // e.g. "12:00"
}

model Client {
  id        String    @id @default(uuid())
  name      String
  phone     String    @unique // unique phone number verified by OTP
  email     String?   @unique // optional, used when logging in with Google/Apple
  googleId  String?   @unique // unique identifier for Google OAuth login
  appleId   String?   @unique // unique identifier for Apple OAuth login
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id         String   @id @default(uuid())
  date       DateTime // Selected date & time
  status     String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  notes      String?
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
